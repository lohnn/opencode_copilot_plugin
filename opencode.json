{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [["./opencode_copilot_plugin/mobile-ai.js", { "path": "./mobile_ai" }]],
  "mcp": {
    "azure-devops": {
      "type": "local",
      "command": ["npx", "-y", "@azure-devops/mcp", "Skandia", "--authentication", "azcli"],
      "enabled": true
    },
    "figma": {
      "type": "local",
      "command": ["npx", "-y", "figma-developer-mcp", "--stdio"],
      "enabled": true,
      "environment": {
        "FIGMA_API_KEY": "{env:FIGMA_API_KEY}"
      }
    }
  },
  "permission": {
    "azure-devops_*": "deny",
    "azure-devops_wit_my_work_items": "allow",
    "azure-devops_wit_get_work_item": "allow",
    "azure-devops_wit_get_work_items_batch_by_ids": "allow",
    "azure-devops_wit_get_work_items_for_iteration": "allow",
    "azure-devops_repo_list_pull_requests_by_repo_or_project": "allow",
    "azure-devops_repo_get_pull_request_by_id": "allow",
    "azure-devops_work_list_team_iterations": "allow",
    "figma_*": "deny"
  }
}
